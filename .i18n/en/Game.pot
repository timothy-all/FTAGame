#. §12: `gcd a b`
#. §13: `gcd_exists`
#. §14: ```
#. noncomputable def gcd (a b : Z) : GCD a b := by
#.   by_cases h : a = 0 ∧ b = 0
#.   refine
#.   { g := (0 : Z)
#.     left := by
#.       rw[dvd_def]
#.       use 1
#.       simp
#.       exact h.left
#.     right := by
#.       rw[dvd_def]
#.       use 1
#.       simp
#.       exact h.right
#.     le := by
#.       intro F
#.       contradiction
#.     }
#.   obtain gcd_exists := gcd_exists a b h
